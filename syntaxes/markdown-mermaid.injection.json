{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "scopeName": "markdown.mermaid.codeblock.injection",
  "injectionSelector": "L:text.html.markdown, L:source.gfm",
  "patterns": [
    {
      "name": "markup.fenced_code.block.mermaidjs.markdown",
      "begin": "(^|\\G)(\\s*)(`{3,}|~{3,})\\s*(mermaidjs|mermaid)(?:\\s+[^`]*)?$",
      "beginCaptures": {
        "3": {
          "name": "punctuation.definition.markdown"
        },
        "4": {
          "name": "fenced_code.block.language.markdown"
        }
      },
      "end": "(^|\\G)(\\s*)(`{3,}|~{3,})\\s*$",
      "endCaptures": {
        "3": {
          "name": "punctuation.definition.markdown"
        }
      },
      "contentName": "meta.embedded.block.mermaidjs",
      "patterns": [
        {
          "include": "source.mermaidjs"
        }
      ]
    }
  ]
}
