{
  "compilerOptions": {
    "module": "ES2020",
    "target": "ES2020",
    "outDir": "out/webview",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "rootDir": "src/webview",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": []
  },
  "include": [
    "src/webview/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}
